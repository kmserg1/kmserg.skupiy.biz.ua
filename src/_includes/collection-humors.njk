
<ul>
  {% for item in pagination.items %}

    <div class="item">
	<div class="itemLeft">
	<li><a href="{{ item.url }}"><small>{{ item.date | dateFilter }}<br>{{ item.time | timeFilter | truncate(5,true,'')}}</small>
	</div>
	<div class="itemRight">
        <strong> {{ item.data.title }}</strong></a></li>
	{% set coverImage = item.data.cover_image %} 
	{% if coverImage %} 
	<img src="/images/{{ coverImage }}"  width="100"   height="100" />
	{% endif %} 
       <small>{{ item.content | truncate(80,true) | safe }}</small>
       </div>
    </div>
  {% endfor %}
</ul>
<hr>

{% include "partials/paginations.njk" %}
